# Server
PORT=4000
NODE_ENV=production

# MongoDB — Atlas recommended for production
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/labflow
MONGO_MAX_POOL_SIZE=25
MONGO_MIN_POOL_SIZE=5

# Auth — use a strong random secret (32+ chars)
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_characters

# CORS — comma-separated allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost

# Rate limiting (per IP, per minute)
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# Cluster — number of Node workers (capped at 4 in cluster.js)
CLUSTER_WORKERS=2

# bcrypt cost factor (10 is default; lower = faster but less secure)
BCRYPT_ROUNDS=10

# Uploads
MAX_UPLOAD_MB=5
MAX_UPLOAD_FILES=20
